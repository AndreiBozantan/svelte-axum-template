# enforce LF line endings for all text files
* text=auto eol=lf

# force LF line endings for specific file types
*.rs text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.svelte text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.sh text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# mark lockfiles and generated files as linguist-generated so they are collapsed by default in GitHub diffs
Cargo.lock linguist-generated=true
package-lock.json linguist-generated=true
frontend/package-lock.json linguist-generated=true
.sqlx/*.json linguist-generated=true
openapi.json linguist-generated=true
frontend/src/lib/generated/** linguist-generated=true
