{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "cargo build app",
            "command": "cargo build --package app",
            "problemMatcher": ["$rustc"]
        },
        {
            "type": "shell",
            "label": "xtask: dev - run dev environment",
            "command": "cargo run -p xtask dev run",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "type": "shell",
            "label": "xtask: initialize dev environment",
            "command": "cargo run -p xtask dev init",
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "xtask: reset database",
            "command": "cargo run -p xtask sqlx reset",
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "xtask: status - run status check",
            "command": "cargo run -p xtask dev status",
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "xtask: release - build release container",
            "command": "cargo run -p xtask make release",
            "problemMatcher": ["$rustc"]
        },
        {
            "type": "shell",
            "label": "xtask: commit - run pre-commit checks",
            "command": "cargo run -p xtask pre-commit",
            "problemMatcher": ["$rustc"]
        }
    ]
}
