{
    "explorer.fileNesting.enabled": true,
    "explorer.fileNesting.patterns": {
        "configs.common.toml": "configs.*.toml",
        "Cargo.toml": "Cargo.toml, Cargo.lock, rustfmt.toml, .editorconfig",
        ".gitignore": ".dockerignore, .gitignore, .semgrepignore, .gitattributes",
        "AGENTS.md": "CLAUDE.md, README.md, LICENSE, openapi.json",
        ".env": ".env.example",
        "Dockerfile": "docker-compose.yml",
        "jsconfig.json": "svelte.config.js, tsconfig.json, tsconfig.node.json, vite.config.ts",
        ".prettierrc": ".prettierignore"
    },
    "terminal.integrated.mouseWheelScrollSensitivity": 3,
    "terminal.integrated.gpuAcceleration": "off",
    "cSpell.ignorePaths": ["**/Cargo.lock", "**/settings.json"],
    "cSpell.words": [
        "addgroup",
        "adduser",
        "agentic",
        "AUTOINCREMENT",
        "batcat",
        "binstall",
        "chrono",
        "clippy",
        "codegen",
        "cxapi",
        "cxdbpr",
        "distroless",
        "dotenvy",
        "exfiltrated",
        "fuser",
        "jsonwebtoken",
        "libsqlite",
        "mimalloc",
        "NOCASE",
        "noexec",
        "nologin",
        "nonroot",
        "nosuid",
        "pipefail",
        "pkce",
        "Referer",
        "reqwest",
        "rfind",
        "rngs",
        "rpassword",
        "rustc",
        "rustflags",
        "rustls",
        "rustup",
        "sccache",
        "semgrep",
        "serde",
        "sqlx",
        "statusline",
        "subfeature",
        "svelaxum",
        "testuser",
        "thiserror",
        "tlnp",
        "tlsv",
        "tmpfs",
        "usermod",
        "utoipa",
        "utoipax",
        "vitest",
        "xtask"
    ],
    "editor.formatOnSave": true,
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust-analyzer"
    },
    "[svelte]": {
        "editor.defaultFormatter": "svelte.svelte-vscode"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    }
}
