{
  "rust-post-edit-validation": {
    "enabled": true,
    "PostToolUse": [
      {
        "matcher": "replace_file_content|multi_replace_file_content|write_to_file",
        "hooks": [
          {
            "type": "command",
            "command": "./.agents/post_tool_hook.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
